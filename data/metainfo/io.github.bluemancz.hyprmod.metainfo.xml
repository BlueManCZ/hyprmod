<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.bluemancz.hyprmod</id>
  <launchable type="desktop-id">io.github.bluemancz.hyprmod.desktop</launchable>

  <name>HyprMod</name>
  <summary>Native settings app for Hyprland</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.bluemancz">
    <name>Ivo Šmerek</name>
  </developer>

  <update_contact>ivo97_AT_centrum.cz</update_contact>

  <description>
    <p>
      HyprMod is a native GTK4/libadwaita settings app for Hyprland.
      Every change applies instantly to the running compositor, and
      your hand-crafted config stays untouched — HyprMod writes only
      to its own hyprland-gui.conf.
    </p>
    <p>Features:</p>
    <ul>
      <li>Live preview — changes apply instantly, no reload needed</li>
      <li>Monitor configuration with layout preview; VRR, HDR, and 10-bit detection</li>
      <li>Bezier curve editor with draggable control points and live animation preview</li>
      <li>Keybind editor with interactive key capture</li>
      <li>Cursor theme picker with live previews</li>
      <li>Profiles — save, name, and switch between complete configurations</li>
      <li>Config DNA — every profile gets a unique visual fingerprint</li>
      <li>Global search across all options (Ctrl+F)</li>
      <li>Undo with Ctrl+Z</li>
    </ul>
  </description>

